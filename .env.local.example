# Email.js Configuration
# Get these from https://www.emailjs.com/

# Your EmailJS Public Key
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=NATtzWU2PEjq7Dfbh

# Your EmailJS Service ID
NEXT_PUBLIC_EMAILJS_SERVICE_ID=service_7kote2p

# Your EmailJS Template ID
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=template_k92m6gi

# ============ SETUP INSTRUCTIONS ============
# 1. Go to https://www.emailjs.com/ and sign up for FREE
# 2. Get your Public Key from: https://dashboard.emailjs.com/settings/api
# 3. Create an Email Service (Gmail, Outlook, etc.)
# 4. Create an Email Template with variables: {{from_name}}, {{from_email}}, {{message}}
# 5. Copy your Service ID and Template ID
# 6. Rename this file to .env.local
# 7. Fill in the values above
# 8. Restart your dev server
#
# Template Body Example:
# From: {{from_name}} ({{from_email}})
# Message: {{message}}
